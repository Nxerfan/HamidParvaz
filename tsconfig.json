{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    "app/components/(Headers)/HeaderMakeYourTour.jsx",
    "app/components/(filters)/Filters.tsx",
    "app/flight/flightch/page.jsx",
    "app/flight/reserve/form/page.tsx",
    "app/tour/tourch/page.jsx",
    "app/userpanel/page.jsx",
    "next.config.ts",
    "dist/types/**/*.ts",
    "dist/dev/types/**/*.ts",
    "app/(support)/cooperation/page.jsx",
    "app/flight/flightse/page.tsx",
    "app/tour/page.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
